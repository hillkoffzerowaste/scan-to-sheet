rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid;
    }

    match /scanEvents/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.code is string
        && request.resource.data.courier is string
        && request.resource.data.type in ['packer', 'admin'];
      allow update, delete: if false;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.code is string
        && request.resource.data.normalizedCode is string
        && request.resource.data.courier is string
        && request.resource.data.date is string
        && request.resource.data.status in [
          'pending',
          'packer_scanned',
          'matched',
          'issue',
          'cancelled',
          'damaged',
          'returned'
        ]
        && request.resource.data.sheetSyncStatus in [
          'pending',
          'synced',
          'failed'
        ];
      allow delete: if false;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'marketplaceOrderId', 'marketplaceSkus'
        ])
        && request.resource.data.marketplaceOrderId is string
        && request.resource.data.marketplaceSkus is list
        && request.resource.data.marketplaceSkus.size() <= 100;
    }

    match /marketplaceOrders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'platform', 'orderId', 'trackingNo', 'normalizedTrackingNo',
          'marketplaceSkus', 'importSource', 'importedAt', 'updatedAt'
        ])
        && request.resource.data.platform in ['shopee', 'lazada', 'tiktok']
        && request.resource.data.orderId is string
        && request.resource.data.trackingNo is string
        && request.resource.data.normalizedTrackingNo is string
        && request.resource.data.marketplaceSkus is list
        && request.resource.data.marketplaceSkus.size() <= 100
        && request.resource.data.importSource == 'web_upload'
        && request.resource.data.importedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.platform + '__' + request.resource.data.orderId == orderId;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'platform', 'orderId', 'trackingNo', 'normalizedTrackingNo',
          'marketplaceSkus', 'importSource', 'importedAt', 'updatedAt'
        ])
        && request.resource.data.platform in ['shopee', 'lazada', 'tiktok']
        && request.resource.data.orderId is string
        && request.resource.data.trackingNo is string
        && request.resource.data.normalizedTrackingNo is string
        && request.resource.data.marketplaceSkus is list
        && request.resource.data.marketplaceSkus.size() <= 100
        && request.resource.data.importSource == 'web_upload'
        && request.resource.data.importedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.platform + '__' + request.resource.data.orderId == orderId;
      allow delete: if false;
    }

    match /syncStatus/{platform} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
