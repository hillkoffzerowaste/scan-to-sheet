VITE_GOOGLE_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-web-oauth-client-secret

# Vercel KV / Upstash Redis REST env:
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Google Cloud setup:
# - OAuth client type: Web application
# - Authorized JavaScript origin for local dev: http://127.0.0.1:5173
# - Authorized JavaScript origin for Vercel: https://scan-to-sheet-ten.vercel.app
# - Authorized redirect URI for local dev: http://127.0.0.1:5173/
# - Authorized redirect URI for Vercel: https://scan-to-sheet-ten.vercel.app/
# - Enable Google Drive API and Google Sheets API
